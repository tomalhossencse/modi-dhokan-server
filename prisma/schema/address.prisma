model Address {
    id        String   @id @default(uuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    label     String
    address   String
    city      String
    state     String
    zip       String
    isDefault Boolean  @default(false)
    lat       Float
    lng       Float
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
