model DeliveryPartner {
    id          String   @id @default(uuid())
    name        String
    email       String   @unique
    password    String
    phone       String
    avatar      String?  @default("")
    vehicleType String?  @default("bike")
    isActive    Boolean? @default(true)
    orders      Order[]
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}
