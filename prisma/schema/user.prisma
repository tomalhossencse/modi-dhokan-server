model User {
    id        String     @id @default(uuid())
    name      String
    email     String     @unique
    password  String
    status    UserStatus @default(ACTIVE)
    phone     String?    @default("")
    avatar    String?    @default("")
    addresses Address[]
    orders    Order[]
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt
}
